{
	"version": "0.2.0",
	"configurations": [
        {
            "name": "HashLink",
            "request": "launch",
            "type": "hl",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": {
				"type" : "hxml",
				"file": "heaps-hl.hxml"
            }
        },
        {
			"type": "chrome",
			"request": "launch",
			"name": "HTML5",
			"url": "file://${workspaceFolder}/index.html",
			"webRoot": "${workspaceFolder}",
			"preLaunchTask": {
				"type" : "hxml",
				"file": "heaps-js.hxml"
			},
		}
	]
}